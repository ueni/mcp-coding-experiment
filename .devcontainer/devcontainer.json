{
  "name": "codebase-tooling-mcp",
  "dockerComposeFile": [
    "../source/docker-compose.yml"
  ],
  "service": "codebase-tooling-mcp",
  "remoteUser": "app",
  "containerUser": "app",
  "workspaceFolder": "/repo",
  "shutdownAction": "stopCompose",
  "containerEnv": {
    "DOCKER_HOST": "unix:///var/run/docker.sock"
  },
  "forwardPorts": [
    8000
  ],
  "portsAttributes": {
    "8000": {
      "label": "MCP Server",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Continue.continue",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker",
        "mhutchie.git-graph"
      ]
    }
  },
  "mounts": [
    "source=${localEnv:HOME}/.continue,target=/home/app/.continue,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.gitconfig,target=/home/app/.gitconfig,type=bind,consistency=cached",
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ]
}
