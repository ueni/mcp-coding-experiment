{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Docker: Build Image",
      "type": "process",
      "command": "docker",
      "args": [
        "build",
        "-t",
        "codebase-tooling-mcp:latest",
        "./source"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "DOCKER_CONFIG": "${workspaceFolder}/.docker-build",
          "DOCKER_BUILDKIT": "1",
          "DOCKER_API_VERSION": "1.42"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Docker: Build Image (No Cache)",
      "type": "process",
      "command": "docker",
      "args": [
        "build",
        "--no-cache",
        "-t",
        "codebase-tooling-mcp:latest",
        "./source"
      ],
      "group": "build",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "DOCKER_CONFIG": "${workspaceFolder}/.docker-build",
          "DOCKER_BUILDKIT": "1",
          "DOCKER_API_VERSION": "1.42"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Docker: Run Container",
      "type": "process",
      "command": "docker",
      "args": [
        "run",
        "-d",
        "--name",
        "codebase-tooling-mcp",
        "-p",
        "127.0.0.1:8000:8000",
        "-p",
        "127.0.0.1:2345:2345",
        "-e",
        "MCP_TRANSPORT=http",
        "-e",
        "ALLOW_MUTATIONS=true",
        "-e",
        "MCP_HTTP_BEARER_TOKEN",
        "-v",
        "${workspaceFolder}:/repo",
        "codebase-tooling-mcp:latest"
      ],
      "group": "none",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Docker: Container Logs",
      "type": "process",
      "command": "docker",
      "args": [
        "logs",
        "--tail",
        "200",
        "codebase-tooling-mcp"
      ],
      "group": "none",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Docker: Stop Container",
      "type": "process",
      "command": "docker",
      "args": [
        "stop",
        "codebase-tooling-mcp"
      ],
      "group": "none",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Docker: Remove Container",
      "type": "process",
      "command": "docker",
      "args": [
        "rm",
        "-f",
        "codebase-tooling-mcp"
      ],
      "group": "none",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "MCP: Workspace Health Check",
      "type": "process",
      "command": "python3",
      "args": [
        "${workspaceFolder}/scripts/vscode_mcp_healthcheck.py"
      ],
      "group": "test",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Devcontainer: CI Smoke Test",
      "type": "process",
      "command": "python3",
      "args": [
        "${workspaceFolder}/scripts/devcontainer_smoke_test.py"
      ],
      "group": "test",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "TEST_IMAGE": "codebase-tooling-mcp:test",
          "MCP_SMOKE_HOST_PORT_MODE": "ephemeral",
          "MCP_SMOKE_REQUIRE_MODEL_PROMPT": "false",
          "OLLAMA_ALLOW_PULL": "false",
          "MCP_SMOKE_SERVER_STARTUP_TIMEOUT_SECONDS": "90",
          "MCP_SMOKE_MODEL_TIMEOUT_SECONDS": "30"
        }
      },
      "problemMatcher": []
    }
  ]
}
