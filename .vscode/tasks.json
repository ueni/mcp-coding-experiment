{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Docker: Build Image",
      "type": "process",
      "command": "docker",
      "args": [
        "build",
        "-t",
        "codebase-tooling-mcp:latest",
        "./source"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Docker: Build Image (No Cache)",
      "type": "process",
      "command": "docker",
      "args": [
        "build",
        "--no-cache",
        "-t",
        "codebase-tooling-mcp:latest",
        "./source"
      ],
      "group": "build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Docker: Compose Build Service",
      "type": "process",
      "command": "docker",
      "args": [
        "compose",
        "-f",
        "source/docker-compose.yml",
        "build",
        "codebase-tooling-mcp"
      ],
      "group": "build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Docker: Compose Pull Service",
      "type": "process",
      "command": "docker",
      "args": [
        "compose",
        "-f",
        "source/docker-compose.yml",
        "pull",
        "codebase-tooling-mcp"
      ],
      "group": "build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Docker: Compose Up Service",
      "type": "process",
      "command": "docker",
      "args": [
        "compose",
        "-f",
        "source/docker-compose.yml",
        "up",
        "-d",
        "codebase-tooling-mcp"
      ],
      "group": "none",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Docker: Compose Logs Service",
      "type": "process",
      "command": "docker",
      "args": [
        "compose",
        "-f",
        "source/docker-compose.yml",
        "logs",
        "--tail",
        "200",
        "codebase-tooling-mcp"
      ],
      "group": "none",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Docker: Compose Down",
      "type": "process",
      "command": "docker",
      "args": [
        "compose",
        "-f",
        "source/docker-compose.yml",
        "down"
      ],
      "group": "none",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
