{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Docker: Build Image",
      "type": "process",
      "command": "docker",
      "args": [
        "build",
        "-t",
        "codebase-tooling-mcp:latest",
        "./source"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "DOCKER_BUILDKIT": "1"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Docker: Build Image (No Cache)",
      "type": "process",
      "command": "docker",
      "args": [
        "build",
        "--no-cache",
        "-t",
        "codebase-tooling-mcp:latest",
        "./source"
      ],
      "group": "build",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "DOCKER_BUILDKIT": "1"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Docker: Run Container",
      "type": "process",
      "command": "docker",
      "args": [
        "run",
        "-d",
        "--name",
        "codebase-tooling-mcp",
        "-p",
        "8000:8000",
        "-e",
        "MCP_TRANSPORT=http",
        "-e",
        "ALLOW_MUTATIONS=true",
        "-v",
        "${workspaceFolder}:/repo",
        "codebase-tooling-mcp:latest"
      ],
      "group": "none",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Docker: Container Logs",
      "type": "process",
      "command": "docker",
      "args": [
        "logs",
        "--tail",
        "200",
        "codebase-tooling-mcp"
      ],
      "group": "none",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Docker: Stop Container",
      "type": "process",
      "command": "docker",
      "args": [
        "stop",
        "codebase-tooling-mcp"
      ],
      "group": "none",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Docker: Remove Container",
      "type": "process",
      "command": "docker",
      "args": [
        "rm",
        "-f",
        "codebase-tooling-mcp"
      ],
      "group": "none",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
